{
  "name": "ai-story-studio-frontend",
  "version": "1.1.0",
  "description": "AI-powered story creation platform frontend built with React, TypeScript, and Vite",
  "main": "app.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "start": "node app.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kalosha959-wq/ai-story-studio-frontend.git"
  },
  "keywords": [
    "ai",
    "story",
    "writing",
    "react",
    "typescript",
    "vite",
    "frontend"
  ],
  "author": "",
  "license": "AGPL-3.0",
  "bugs": {
    "url": "https://github.com/kalosha959-wq/ai-story-studio-frontend/issues"
  },
  "homepage": "https://github.com/kalosha959-wq/ai-story-studio-frontend#readme",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
